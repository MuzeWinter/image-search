{
  "$schema": "https://raw.githubusercontent.com/nicegui-dev/tauri-apps-tauri/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "ZOOBET检索",
  "version": "0.1.0",
  "identifier": "com.zoobet.image-search",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ZOOBET检索",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN",
        "bannerPath": "",
        "dialogImagePath": ""
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}