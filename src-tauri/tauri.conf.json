{
  "$schema": "https://raw.githubusercontent.com/nicegui-dev/tauri-apps-tauri/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "ZOOBET检索",
  "version": "0.1.0",
  "identifier": "com.zoobet.image-search",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ZOOBET检索",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
