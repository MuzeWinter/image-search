{
  "reviewCommands": [
    {
      "name": "TypeScript type-check",
      "command": "npx tsc --noEmit",
      "required": true
    },
    {
      "name": "Vite production build",
      "command": "npm run build",
      "required": true
    },
    {
      "name": "Cargo build",
      "command": "cargo build --manifest-path src-tauri/Cargo.toml 2>&1",
      "required": true
    },
    {
      "name": "Python backend syntax",
      "command": "python -m py_compile backend/main.py",
      "required": true
    },
    {
      "name": "Git status",
      "command": "git status --short",
      "required": true
    }
  ],
  "mojibakeScan": {
    "enabled": true,
    "paths": ["src", "src-tauri/src", "backend", "docs"],
    "extensions": ["*.ts", "*.tsx", "*.rs", "*.py", "*.json", "*.md", "*.css"]
  },
  "requiredFiles": [
    "AGENTS.md",
    "CLAUDE.md",
    "docs/AI-CODING-RULES.md",
    "src/main.tsx",
    "src/App.tsx",
    "src-tauri/src/main.rs",
    "src-tauri/Cargo.toml",
    "backend/main.py"
  ]
}
